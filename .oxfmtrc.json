{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "singleQuote": true,
    "jsxSingleQuote": true,
    "quoteProps": "consistent",
    "semi": false,
    "endOfLine": "lf",
    "printWidth": 80,
    "tabWidth": 4,
    "trailingComma": "none",
    "ignorePatterns": ["*-lock.{yaml,json}"],
    "sortImports": {
        "order": "desc",
        "internalPattern": ["~/", "~quartzConfig", "~quartzLayout"],
        "groups": [
            "type-import",
            "type-builtin",
            "value-builtin",
            "type-external",
            "value-external",
            "type-internal",
            "value-internal",
            "type-parent",
            "value-parent",
            "type-sibling",
            "value-sibling",
            "type-index",
            "value-index",
            "unknown"
        ]
    }
}
