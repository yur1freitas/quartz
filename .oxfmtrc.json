{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "singleQuote": true,
    "jsxSingleQuote": true,
    "quoteProps": "consistent",
    "semi": false,
    "endOfLine": "lf",
    "printWidth": 80,
    "tabWidth": 4,
    "trailingComma": "none",
    "ignorePatterns": ["*-lock.{yaml,json}"],
    "sortImports": {
        "order": "desc"
    }
}
